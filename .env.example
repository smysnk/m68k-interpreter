# Local interpreter IDE defaults.
#
# `yarn dev` runs through `mono-helper`, which reserves `WEB_PORT`
# automatically. Set `WEB_PORT` only if you plan to use `yarn dev:raw`.

WEB_OPEN=true

# Optional local overrides.
# WEB_PORT=3000
# WEB_HOST=127.0.0.1
# TEST_STATION_CLI_PATH=../test-station/packages/cli/src/cli.js

TEST_STATION_INGEST_ENDPOINT=https://test-station.smysnk.com/api/ingest
TEST_STATION_INGEST_PROJECT_KEY=m68k-interpreter
TEST_STATION_INGEST_SHARED_KEY=
